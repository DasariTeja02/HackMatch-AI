        <script><![CDATA[(function executeRule(current, previous) {

    var score = 0;

    var student1 = current.student;
    var student2 = current.recommended_student;

    var skillGR1 = new GlideRecord('x_1971723_hackma_0_student_skill');
    skillGR1.addQuery('student', student1);
    skillGR1.query();

    while (skillGR1.next()) {

        var skillGR2 = new GlideRecord('x_1971723_hackma_0_student_skill');
        skillGR2.addQuery('student', student2);
        skillGR2.addQuery('skill', skillGR1.skill);
        skillGR2.query();

        if (skillGR2.next()) {
            score = 50;
            break;
        }
    }

    current.compatibility_score = score;

})(current, previous);]]></script>
